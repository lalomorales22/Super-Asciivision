{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Super ASCIIVision",
  "version": "0.1.2",
  "identifier": "com.megabrain2.superasciivision",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Super ASCIIVision",
        "width": 1420,
        "height": 860,
        "minWidth": 1180,
        "minHeight": 680,
        "visible": true,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.x.ai wss://api.x.ai http://localhost:11434 ipc: http://ipc.localhost; img-src 'self' data: blob: asset: https://asset.localhost; media-src 'self' data: blob: asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$APPDATA/**", "$LOCALDATA/**", "$AUDIO/**", "$DESKTOP/**", "$DOCUMENT/**", "$DOWNLOAD/**"],
          "deny": ["$HOME/.ssh/**", "$HOME/.gnupg/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/asciivision"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
